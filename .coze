[project]
entrypoint = "server.js"
requires = [ "nodejs-24" ]
template = "expo"
version = "0.0.14"
appliedPatches = [ ]

[preview]
preview_enable = "enabled"

[dev]
build = [ "bash", "scripts/coze-preview-build.sh" ]
run = [ "bash", "scripts/coze-preview-run.sh" ]

[deploy]
build = [ "bash", ".cozeproj/scripts/prod_build.sh" ]
run = [ "bash", ".cozeproj/scripts/prod_run.sh" ]
build_app_dir = "./client"
