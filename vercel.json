{
  "buildCommand": "cd client && npx expo export --platform web",
  "outputDirectory": "client/web-static",
  "installCommand": "cd client && npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://word-voyage-api-production.up.railway.app/api/:path*" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "*" }
      ]
    }
  ]
}
